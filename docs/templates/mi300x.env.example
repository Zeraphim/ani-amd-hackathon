# Copy this file to the repository root as .env.mi300x.
# Keep .env.mi300x private: it contains the vLLM bearer token.

# Tier 2 -> Tier 3
ANI_BACKEND=mi300x
ANI_BASE_URL=http://127.0.0.1:8001/v1

# Serve the base Gemma model with the existing Ani LoRA adapter.
ANI_BASE_MODEL=google/gemma-3-27b-it
ANI_MODEL=ani-grader
ANI_LORA_PATH=/shared-docker/ani-artifacts/ani-gemma-grader-lora
ANI_LORA_NAME=ani-grader

# Required by both launchers. Generate a new private value; never commit it.
FIREWORKS_API_KEY=

# Local runtime settings on the MI300X.
HF_HOME=/shared-docker/hf-cache
PORT=8001
ANI_API_HOST=127.0.0.1
ANI_API_PORT=8000
GPU_MEMORY_UTILIZATION=0.80
VLLM_IMAGE=vllm/vllm-openai-rocm:v0.23.0

# Optional. Needed only to warm an empty Hugging Face cache after accepting the
# Gemma 3 license. Use it with `huggingface-cli login`, then remove it from the
# private file if preferred.
HUGGINGFACE_TOKEN=
